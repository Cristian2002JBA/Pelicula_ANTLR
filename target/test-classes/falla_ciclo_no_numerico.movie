premiere {
    subtitle("--- PRUEBA: CICLO REPLAY NO NUMERICO ---");
    
    // ERROR SEMÁNTICO: Tu ciclo REPLAY exige que la variable de control (toma)
    // sea un INT o FLOAT. Aquí estamos usando texto ("primera").
    
    replay(toma = "primera"; toma == "primera"; toma = "segunda") {
        subtitle("Grabando...");
    }
    
    subtitle("¡Corten! El reloj del director no sabe contar con palabras.");
}
