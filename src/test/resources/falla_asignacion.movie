premiere {
    subtitle("--- PRUEBA: ASIGNACION INCOMPATIBLE ---");
    
    // El director declara el presupuesto inicial como un número entero
    
    cast presupuesto_efectos = 250;
    
    // ERROR SEMÁNTICO: Producción intenta cambiar el valor de un número a un texto (STRING a INT)
    presupuesto_efectos = "Ilimitado";
    
    subtitle("¡Corten! Este mensaje no se mostrará porque no puedes cambiar el tipo de dato de una variable.");
}
